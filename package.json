{
  "name": "@cucumber/message-streams",
  "version": "5.0.1",
  "description": "Streams for reading/writing messages",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
